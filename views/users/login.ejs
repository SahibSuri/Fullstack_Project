<% layout('layouts/boilerplate') %>

<div class="home-wrapper">
    <div class="hero-section-advanced d-flex align-items-center justify-content-center text-center" style="min-height: 30vh; background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.8)), url('https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=1920&q=80') center/cover;">
        <div class="container animate-fade-in">
            <h1 class="hero-title" style="color: #d4af37; font-family: 'Playfair Display', serif; font-weight: 700;">LOGIN</h1>
            <p class="hero-subtitle text-white-50">
                Welcome back to Empire's Hotel
            </p>
        </div>
    </div>

    <div class="container py-5 my-4 d-flex justify-content-center">
        <div class="col-lg-6 col-md-8 col-sm-10 animate-slide-up">
            <div class="glass-content-panel p-4 p-md-5" style="background: rgba(18, 18, 18, 0.85); border: 1px solid rgba(212, 175, 55, 0.3); border-radius: 12px; box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
                
                <h2 class="text-center mb-4" style="color: #d4af37; font-family: 'Playfair Display', serif; font-weight: 600; letter-spacing: 1px;">Sign Up</h2>
                
                <form action="/login" method="POST" class="needs-validation" novalidate>
                    
                    <div class="mb-3">
                        <label for="username" class="form-label text-secondary" style="color: #d4af37 !important;">Username</label>
                        <input type="text" 
                               id="username" 
                               name="username" 
                               class="form-control bg-dark text-white border-secondary" 
                               style="border-color: rgba(212, 175, 55, 0.3) !important;" 
                               placeholder="Choose a username" 
                               required>
                        <div class="invalid-feedback">
                            Please choose a username.
                        </div>
                    </div>

                    <!-- <div class="mb-3">
                        <label for="email" class="form-label text-secondary" style="color: #d4af37 !important;">Email Address</label>
                        <input type="email" 
                               id="email" 
                               name="email" 
                               class="form-control bg-dark text-white border-secondary" 
                               style="border-color: rgba(212, 175, 55, 0.3) !important;" 
                               placeholder="name@example.com" 
                               required>
                        <div class="invalid-feedback">
                            Please enter a valid email address.
                        </div>
                    </div> -->

                    <div class="mb-4">
                        <label for="password" class="form-label text-secondary" style="color: #d4af37 !important;">Password</label>
                        <input type="password" 
                               id="password" 
                               name="password" 
                               class="form-control bg-dark text-white border-secondary" 
                               style="border-color: rgba(212, 175, 55, 0.3) !important;" 
                               placeholder="Create a strong password" 
                               required>
                        <div class="invalid-feedback">
                            Please enter your password.
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" 
                                class="btn px-5 py-3 text-uppercase fw-bold" 
                                style="background-color: #d4af37; color: #000000; border: none; letter-spacing: 1.5px; transition: all 0.3s ease;">
                            LOGIN
                        </button>
                    </div>

                    <div class="text-center mt-4">
                        <p class="text-secondary" style="font-size: 0.9rem;">
                            Already have an account? <a href="/login" style="color: #d4af37; text-decoration: none; font-weight: 500;">Login here</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        background-color: #1a1a1a !important;
        color: #fff !important;
        border-color: #d4af37 !important;
        box-shadow: 0 0 0 0.25rem rgba(212, 175, 55, 0.25) !important;
    }
</style>