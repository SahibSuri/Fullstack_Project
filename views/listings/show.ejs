<% layout('layouts/boilerplate') %>

<div class="show-page-wrapper py-5">
    <div class="container mt-3">
        <div class="row justify-content-center">
            
            <div class="col-lg-10 mb-4 animate-fade-in">
                <h2 class="display-5 fw-bold text-white"><%= listingID.title %></h2>
                <p class="text-secondary"><i class="fa-solid fa-location-dot me-2"></i><%= listingID.location %>, <%= listingID.country %></p>
            </div>

            <div class="col-lg-10 mb-5 animate-slide-up">
                <div class="show-card-img shadow-lg">
                    <img src="<%= listingID.image.url %>" class="img-fluid rounded-4" alt="listing_image">
                </div>
            </div>

            <div class="col-lg-10">
                <div class="glass-card p-4 p-md-5 animate-slide-up-delayed">
                    <div class="row">
                        <div class="col-md-8">
                            <h4 class="text-white mb-3">Experience Purity</h4>
                            <p class="listing-description text-secondary">
                                <%= listingID.description %>
                            </p>
                        </div>
                        <div class="col-md-4 text-md-end mt-4 mt-md-0">
                            <div class="price-tag mb-4">
                                <span class="h2 text-white fw-bold">₹<%= listingID.price.toLocaleString("en-IN") %></span>
                                <span class="text-secondary d-block">per night</span>
                            </div>
                            
                            <div class="d-flex flex-column gap-3">
                                <a href="/listing/<%= listingID._id %>/edit" class="btn btn-outline-light rounded-pill py-2">
                                    <i class="fa-regular fa-pen-to-square me-2"></i>Edit Details
                                </a>
                                <form action="/listing/<%= listingID._id %>?_method=DELETE" method="POST" class="w-100">
                                    <button class="btn btn-dark-danger w-100 rounded-pill py-2">
                                        <i class="fa-solid fa-trash-can me-2"></i>Delete Listing
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>