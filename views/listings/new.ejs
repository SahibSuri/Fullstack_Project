<% layout('layouts/boilerplate') %>
<body>
    <h2>Create a New Listing</h2>
    <form action="/listing" method="post">
        <input type="text" name="listing[title]" placeholder="Enter the title">
        <br>
        <textarea name="listing[description]" id="" placeholder="write about your hotel"></textarea>
        <br>
        <input type="text" name="listing[image]" placeholder="Enter image (URL)">
        <br>
        <input type="text" name="listing[price]" placeholder="Enter the price">
        <br>
        <input type="text" name="listing[locat]ion" placeholder="Enter the location">
        <br>
        <input type="text" name="listing[country]" placeholder="Enter the country">
        <br>
        <button>ADD</button>
    </form>
</body>
